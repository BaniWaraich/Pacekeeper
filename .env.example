# Neon Postgres — use the POOLED connection string (serverless functions must
# use the pooler, not the direct connection). Tech doc §7.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/pacekeeper?sslmode=require"

# Auth.js — generate with: npx auth secret (or: openssl rand -base64 32)
AUTH_SECRET=""

# Gemini — optional. Absence disables the two AI buttons and nothing else (tech doc §7).
GEMINI_API_KEY=""

# PostHog — the NEXT_PUBLIC_ key is public by design (tech doc §8 #10).
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
